GITHUB_WEBHOOK_SECRET=change-me
ALLOWED_USERS=htlin222
BOT_USERNAME=your-bot-username
PORT=8080

# Command Prefix (optional, defaults to @claude)
# The prefix used to trigger bot commands in comments
# COMMAND_PREFIX=@claude

# Bot GitHub Token (optional)
# If set, all gh CLI commands will use this GitHub account instead of the default gh auth
# BOT_GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Bot Git Identity (optional)
# If set, all git commits will use this identity instead of the global git config
# BOT_GIT_NAME=Claude Bot
# BOT_GIT_EMAIL=claude-bot@example.com

# Max Concurrent Jobs (optional, defaults to 3)
# MAX_CONCURRENT=3
